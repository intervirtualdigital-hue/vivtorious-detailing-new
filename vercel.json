{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": null,
  "installCommand": "echo 'static site - skipping install'",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/pricing", "destination": "/pricing.html" },
    { "source": "/packages", "destination": "/packages.html" },
    { "source": "/booking", "destination": "/booking.html" },
    { "source": "/thankyou", "destination": "/thankyou.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/commercial-contact", "destination": "/commercial-contact.html" },
    { "source": "/commercial-thank-you", "destination": "/commercial-thank-you.html" },
    { "source": "/update", "destination": "/update.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(jpg|jpeg|png|webp|svg|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, immutable" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
